---
# roles/homepage/templates/services.yaml.j2
# Templated (not static copy) so widget API keys/secrets can be injected via
# HOMEPAGE_VAR_* env-substitution placeholders, which Homepage substitutes at
# runtime from /opt/homepage/.env (generated by 4_homepage_widgets.yml). Keeps
# secrets out of this file and out of `ansible --diff` output.

- Media:
    - Jellyfin:
        icon: jellyfin.png
        href: https://jellyfin.welpes.com
        description: Media server

    - Jellyseerr:
        icon: jellyseerr.png
        href: https://jellyseerr.welpes.com
        description: Media requests
        widget:
          type: seerr
          url: http://192.168.1.109:5055
          key: {{ '{{HOMEPAGE_VAR_SEERR_KEY}}' }}

    - Navidrome:
        icon: navidrome.png
        href: https://navidrome.welpes.com
        description: Music streaming

- Arr Suite:
    - Sonarr:
        icon: sonarr.png
        href: https://sonarr.welpes.com
        description: TV management
        widget:
          type: sonarr
          url: http://192.168.1.104:8989
          key: {{ '{{HOMEPAGE_VAR_SONARR_KEY}}' }}
          fields: ["wanted", "queued", "series"]

    - Radarr:
        icon: radarr.png
        href: https://radarr.welpes.com
        description: Movie management
        widget:
          type: radarr
          url: http://192.168.1.105:7878
          key: {{ '{{HOMEPAGE_VAR_RADARR_KEY}}' }}
          fields: ["wanted", "queued", "movies"]

    - Lidarr:
        icon: lidarr.png
        href: https://lidarr.welpes.com
        description: Music management
        widget:
          type: lidarr
          url: http://192.168.1.101:8686
          key: {{ '{{HOMEPAGE_VAR_LIDARR_KEY}}' }}
          fields: ["wanted", "queued", "artists"]

    - Prowlarr:
        icon: prowlarr.png
        href: https://prowlarr.welpes.com
        description: Indexer management
        widget:
          type: prowlarr
          url: http://192.168.1.110:9696
          key: {{ '{{HOMEPAGE_VAR_PROWLARR_KEY}}' }}
          fields: ["numberOfGrabs", "numberOfQueries", "numberOfFailGrabs", "numberOfFailQueries"]

    - Bazarr:
        icon: bazarr.png
        href: https://bazarr.welpes.com
        description: Subtitles
        widget:
          type: bazarr
          url: http://192.168.1.112:6767
          key: {{ '{{HOMEPAGE_VAR_BAZARR_KEY}}' }}
          fields: ["missingEpisodes", "missingMovies"]

    - Transmission:
        icon: transmission.png
        href: https://transmission.welpes.com/transmission/web
        description: Torrent client
        widget:
          type: transmission
          url: http://192.168.1.103:9091
          fields: ["leech", "download", "seed", "upload"]

    - Flaresolverr:
        icon: flaresolverr.png
        href: http://192.168.1.111:8191
        description: Cloudflare bypass proxy

- Infrastructure:
    - Proxmox:
        icon: proxmox.png
        href: https://192.168.1.253:8006
        description: Hypervisor
        widget:
          type: proxmox
          url: https://192.168.1.253:8006
          username: {{ '{{HOMEPAGE_VAR_PROXMOX_USER}}' }}
          password: {{ '{{HOMEPAGE_VAR_PROXMOX_PASSWORD}}' }}
          node: {{ proxmox_node }}
          fields: ["vms", "lxc", "resources.cpu", "resources.mem"]

    - Pi-hole:
        icon: pi-hole.png
        href: https://pihole.welpes.com/admin
        description: DNS / ad-block
        widget:
          type: pihole
          url: http://192.168.1.100
          version: 6
          key: {{ '{{HOMEPAGE_VAR_PIHOLE_KEY}}' }}
          fields: ["queries", "blocked", "blocked_percent"]

    - Semaphore:
        icon: semaphore.png
        href: https://semaphore.welpes.com
        description: Ansible CI/CD

    - Forgejo:
        icon: forgejo.png
        href: https://forgejo.welpes.com
        description: Git hosting

    - Wiki:
        icon: mdi-book-open-variant
        href: https://wiki.welpes.com
        description: LAN/network reference

- Tasks:
    - Jellyfin Refresh:
        icon: jellyfin.png
        href: https://semaphore.welpes.com/project/1/templates/4
        description: Force a library scan now

    - Normalize Media Now:
        icon: ffmpeg.png
        href: https://semaphore.welpes.com/project/1/templates/5
        description: Run today's transcode/downmix job now
